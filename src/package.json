{
  "name": "disha-client",
  "version": "1.0.0",
  "description": "Disha — Medical Desert Planner (React client built into client/dist for FastAPI to serve)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b tsconfig.client.json && vite build --config client/vite.config.ts",
    "postinstall": "npm run build",
    "dev": "vite --config client/vite.config.ts"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "0.546.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router": "7.13.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@tailwindcss/vite": "4.1.17",
    "@types/leaflet": "^1.9.14",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.0.4",
    "autoprefixer": "10.4.21",
    "tailwindcss": "4.0.14",
    "typescript": "5.9.3",
    "vite": "^5.4.0"
  }
}
