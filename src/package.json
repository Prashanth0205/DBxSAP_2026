{
  "name": "disha",
  "version": "1.0.0",
  "description": "Disha — Medical Desert Planner on Databricks Apps",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=./.env ./server/server.ts",
    "build:client": "tsc -b tsconfig.client.json && vite build --config client/vite.config.ts",
    "build:server": "tsc -b tsconfig.server.json && tsdown -c tsdown.server.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "NODE_ENV=production node --env-file-if-exists=./.env ./dist/server.js",
    "typecheck": "tsc -b tsconfig.server.json && tsc -b tsconfig.client.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@databricks/appkit": "0.38.1",
    "@databricks/appkit-ui": "0.38.1",
    "clsx": "2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "0.546.0",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router": "7.13.0",
    "tailwind-merge": "3.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@tailwindcss/postcss": "4.1.17",
    "@tailwindcss/vite": "4.1.17",
    "@types/leaflet": "^1.9.14",
    "@types/express": "5.0.5",
    "@types/node": "24.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.0.4",
    "autoprefixer": "10.4.21",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "tailwindcss": "4.0.14",
    "tsdown": "0.20.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "^5.4.0"
  }
}
